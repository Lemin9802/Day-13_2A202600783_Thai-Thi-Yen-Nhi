{
  "provider": "openai",
  "model": "gpt-5.4-nano",
  "model_price_tier": "economy",
  "max_steps": 6,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 5,
  "verbose_system": false,
  "timeout_ms": 25000,
  "max_completion_tokens": 700,
  "retry": {"enabled": true, "max_attempts": 2, "backoff_ms": 250},
  "cache": {"enabled": true, "max_size": 1000},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 6,
  "tool_error_rate": 0.02,
  "catalog_override": {},
  "route_rules": [],
  "planner": true,
  "verify": true,
  "self_consistency": 2,
  "tool_budget": 4,
  "prompt_file": "solution/prompt.txt",
  "examples_file": "solution/examples.json"
}
